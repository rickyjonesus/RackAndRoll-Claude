{
  "name": "@rackandroll/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "SWC_NODE_PROJECT=apps/api/tsconfig.app.json node --watch -r @swc-node/register apps/api/src/main.ts",
    "dev:web": "nx serve web",
    "build:api": "cd apps/api && webpack-cli build --node-env=production",
    "build:web": "node apps/web/scripts/set-prod-env.js && nx build web",
    "db:migrate": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "db:push": "prisma db push --schema apps/api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema apps/api/prisma/schema.prisma",
    "test:api": "jest --config apps/api/jest.config.js",
    "test:web": "nx test web",
    "test": "pnpm test:api && pnpm test:web",
    "lint:api": "eslint apps/api/src",
    "lint:web": "nx lint web",
    "lint": "pnpm lint:api && pnpm lint:web"
  },
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
