
# ── Database ─────────────────────────────────────────────────────────────────
# Option A — local Postgres (docker compose --profile local up):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rackandroll"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/rackandroll"

# Option B — Supabase (transaction pooler for runtime, direct for migrations):
DATABASE_URL="postgresql://postgres.<project-ref>:[DB-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[DB-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres"

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3000

# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── OAuth — Apple ─────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=com.yourapp.serviceid
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback
